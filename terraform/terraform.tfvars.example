# terraform/terraform.tfvars.example
# Copy to terraform.tfvars and fill in values. Never commit terraform.tfvars.
#
# Credentials should be provided via environment variables (see provider.tf).
# Only non-secret configuration belongs here.

# Snowflake connection is configured via environment variables (see provider.tf).
# Set these in your shell before running terraform:
#   export SNOWFLAKE_ACCOUNT=xy12345.us-east-1
#   export SNOWFLAKE_USER=TF_SYSADMIN
#   export SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/tf_rsa_key.p8
#   export SNOWFLAKE_ROLE=SYSADMIN

# Environment tag value applied to all resources
environment = "prod"

# Notify these users when resource monitor thresholds are hit
# Must be valid Snowflake usernames (ACCOUNTADMIN holders recommended)
resource_monitor_notify_users = ["ADMIN"]
